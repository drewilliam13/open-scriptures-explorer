# Local reader and local search do not require environment variables.
# Keep DATABASE_URL only if you use Prisma locally for future data work.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/open_scripture_explorer"

# Optional: enables web-backed AI reference discovery in /api/search.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
OPENAI_TIMEOUT_MS="8000"
DEFAULT_AI_PROVIDER="openai"

# Optional: used for generated metadata, robots.txt, and sitemap.xml.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Per-runtime search throttling. Use Vercel/KV or similar later if global limits are needed.
SEARCH_RATE_LIMIT_MAX="30"
SEARCH_RATE_LIMIT_WINDOW_SECONDS="60"
TRUST_PROXY_HEADERS="false"
APP_ENV="development"
